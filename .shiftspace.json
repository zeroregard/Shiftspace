{
  "actions": [
    {
      "id": "fmt",
      "label": "fmt",
      "command": "bun run fmt:check",
      "type": "check",
      "icon": "whitespace"
    },
    {
      "id": "lint",
      "label": "lint",
      "command": "bun run lint:check",
      "type": "check",
      "icon": "checklist"
    },
    {
      "id": "typecheck",
      "label": "tsc",
      "command": "bun run typecheck",
      "type": "check",
      "icon": "symbol-parameter"
    },
    {
      "id": "test",
      "label": "test",
      "command": "bun run test",
      "type": "check",
      "icon": "beaker"
    },
    {
      "id": "build",
      "label": "build",
      "command": "bun run build",
      "type": "check",
      "icon": "build"
    }
  ],
  "pipelines": {
    "verify": {
      "steps": ["fmt", "lint", "typecheck", "test"],
      "stopOnFailure": false
    }
  },
  "smells": [
    {
      "id": "eslint-disable",
      "label": "ESLint Disable",
      "pattern": "eslint-disable",
      "threshold": 1,
      "fileTypes": [".jsx", ".ts", ".tsx"]
    },
    {
      "id": "llm-comment",
      "label": "LLM Comment",
      "pattern": "// ---------------------------------------------------------------------------",
      "threshold": "1"
    },
    {
      "id": "console-log",
      "label": "Console Log",
      "pattern": "console\\.log",
      "threshold": 1,
      "fileTypes": [".js", ".jsx", ".ts", ".tsx"],
      "excludePatterns": ["*.test.ts", "*.test.tsx", "*.spec.ts", "*.spec.tsx"]
    },
    {
      "id": "use-effect-overuse",
      "label": "useEffect Overuse",
      "pattern": "useEffect\\s*\\(",
      "threshold": 5,
      "fileTypes": [".jsx", ".tsx"]
    },
    {
      "id": "todo-comment",
      "label": "TODO Comment",
      "pattern": "//\\s*TODO",
      "threshold": 1
    },
    {
      "id": "legacy",
      "label": "Legacy",
      "pattern": "Legacy",
      "threshold": "1"
    },
    {
      "id": "backwards",
      "label": "Backwards compatability",
      "pattern": "Backwards",
      "threshold": "1"
    }
  ]
}
