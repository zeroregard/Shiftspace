{
  "name": "shiftspace",
  "displayName": "Shiftspace",
  "description": "Worktree manager and code review tool — inspect branches, spot code smells, and run checks before you open a PR",
  "preview": true,
  "version": "0.1.52",
  "publisher": "shiftspace",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeroregard/shiftspace"
  },
  "homepage": "https://github.com/zeroregard/Shiftspace#readme",
  "bugs": {
    "url": "https://github.com/zeroregard/Shiftspace/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "git",
    "worktree",
    "diff",
    "source control",
    "code review",
    "code smells",
    "agent",
    "AI",
    "worktree management",
    "monorepo",
    "checks",
    "lint",
    "ci",
    "MCP",
    "inspection"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "icons": {
      "shiftspace-icon": {
        "description": "Shiftspace icon",
        "default": {
          "fontPath": "media/shiftspace-icons.woff",
          "fontCharacter": "\\F101"
        }
      }
    },
    "themes": [
      {
        "label": "Shiftspace Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/shiftspace-dark.json"
      },
      {
        "label": "Shiftspace Light",
        "uiTheme": "vs",
        "path": "./themes/shiftspace-light.json"
      }
    ],
    "commands": [
      {
        "command": "shiftspace.toggle",
        "title": "Toggle",
        "category": "Shiftspace"
      },
      {
        "command": "shiftspace.openTab",
        "title": "Open as Tab",
        "category": "Shiftspace"
      },
      {
        "command": "shiftspace.detectActions",
        "title": "Detect Actions",
        "category": "Shiftspace"
      },
      {
        "command": "shiftspace.recheckInsights",
        "title": "Recheck Insights",
        "category": "Shiftspace"
      }
    ],
    "keybindings": [
      {
        "command": "shiftspace.toggle",
        "key": "shift+space",
        "when": "!inputFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shiftspace",
          "title": "Shiftspace",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "shiftspace": [
        {
          "type": "webview",
          "id": "shiftspace.sidebar",
          "name": "Shiftspace"
        }
      ]
    },
    "configuration": {
      "title": "Shiftspace",
      "properties": {
        "shiftspace.ignorePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Glob patterns for files to hide from the Shiftspace view. Examples: *.lock, **/lang/*.json, *.min.js",
          "scope": "resource"
        },
        "shiftspace.additionalActions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the action"
              },
              "label": {
                "type": "string",
                "description": "Display name"
              },
              "command": {
                "type": "string",
                "description": "Shell command to run"
              },
              "type": {
                "type": "string",
                "enum": [
                  "check",
                  "service"
                ],
                "description": "check = one-shot (pass/fail), service = long-running"
              },
              "icon": {
                "type": "string",
                "description": "Codicon name (e.g. 'play', 'beaker', 'check')"
              }
            },
            "required": [
              "id",
              "label",
              "command",
              "type",
              "icon"
            ]
          },
          "default": [],
          "description": "Additional personal actions beyond what's defined in .shiftspace.json. Personal overrides win on duplicate ID.",
          "scope": "resource"
        },
        "shiftspace.insights.codeSmells.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable code smell detection based on rules defined in .shiftspace.json (smells array). Findings appear as ⚠ pills on file nodes in Inspection mode.",
          "scope": "resource"
        },
        "shiftspace.mcpConfigured": {
          "type": "boolean",
          "default": false,
          "description": "Whether the MCP server auto-configuration prompt has been shown.",
          "scope": "application"
        },
        "shiftspace.insights.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show compiler errors and lint warnings from VSCode diagnostics on file nodes in Inspection mode",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "build:ext": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --sourcemap --metafile=dist/meta-extension.json --outfile=dist/extension.js",
    "build:mcp": "esbuild src/mcp/mcp-server.ts --bundle --platform=node --format=esm --metafile=dist/meta-mcp.json --outfile=dist/mcp-server.mjs",
    "build:webview": "vite build && cp src/webview/vscode-theme.css dist/webview/vscode-theme.css && mkdir -p dist/webview/codicons && cp node_modules/@vscode/codicons/dist/codicon.css dist/webview/codicons/ && cp node_modules/@vscode/codicons/dist/codicon.ttf dist/webview/codicons/",
    "build": "bun run build:webview && bun run build:ext && bun run build:mcp",
    "watch:ext": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --sourcemap --outfile=dist/extension.js --watch",
    "watch:webview": "vite build --watch",
    "watch": "bun run build:webview && bun run watch:ext",
    "package": "vsce package --no-dependencies",
    "local-install": "rm -f shiftspace-*.vsix && vsce package --no-dependencies && code --install-extension shiftspace-*.vsix",
    "typecheck": "tsgo --noEmit && tsgo -p tsconfig.webview.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@shiftspace/renderer": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.3.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "^0.25.0",
    "fantasticon": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^3.0.0"
  }
}
