{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "packages/ui": {
      "entry": ["src/*.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/renderer": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": []
    },
    "apps/preview": {
      "project": ["src/**/*.{ts,tsx}", "e2e/**/*.ts"],
      "ignoreDependencies": ["tailwindcss", "babel-plugin-react-compiler"]
    },
    "packages/renderer-browser-tests": {
      "entry": ["src/**/*.spec.tsx", "playwright/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}", "playwright/**/*.{ts,tsx}", "playwright-ct.config.ts"],
      "ignoreDependencies": [
        "tailwindcss",
        "babel-plugin-react-compiler",
        "@playwright/experimental-ct-react",
        "@playwright/test",
        "@tailwindcss/vite",
        "@vitejs/plugin-react",
        "vite"
      ]
    },
    "apps/vscode-ext": {
      "entry": ["src/webview/index.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "@types/vscode",
        "@vscode/codicons",
        "tailwindcss",
        "babel-plugin-react-compiler"
      ]
    }
  },
  "ignore": ["**/*.d.ts"],
  "ignoreDependencies": ["@typescript/native-preview", "lint-staged"],
  "ignoreBinaries": ["code", "ovsx", "playwright"],
  "tags": ["+@public"]
}
