{
  "name": "@shiftspace/renderer-browser-tests",
  "targets": {
    "ct:folder-node": {
      "command": "bun run test:ct -- src/folder-node.spec.tsx",
      "options": { "cwd": "packages/renderer-browser-tests" },
      "cache": true,
      "inputs": ["{projectRoot}/src/folder-node.spec.tsx", "ctShared", "rendererCore"],
      "outputs": ["{projectRoot}/__screenshots__/folder-node.spec.tsx"]
    },
    "ct:file-node": {
      "command": "bun run test:ct -- src/file-node.spec.tsx",
      "options": { "cwd": "packages/renderer-browser-tests" },
      "cache": true,
      "inputs": ["{projectRoot}/src/file-node.spec.tsx", "ctShared", "rendererCore"],
      "outputs": ["{projectRoot}/__screenshots__/file-node.spec.tsx"]
    },
    "ct:file-list-panel": {
      "command": "bun run test:ct -- src/file-list-panel.spec.tsx",
      "options": { "cwd": "packages/renderer-browser-tests" },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/file-list-panel.spec.tsx",
        "ctShared",
        "rendererCore",
        "rendererInspection"
      ],
      "outputs": ["{projectRoot}/__screenshots__/file-list-panel.spec.tsx"]
    },
    "ct:worktree-card": {
      "command": "bun run test:ct -- src/worktree-card.spec.tsx",
      "options": { "cwd": "packages/renderer-browser-tests" },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/worktree-card.spec.tsx",
        "ctShared",
        "rendererCore",
        "rendererGrove"
      ],
      "outputs": ["{projectRoot}/__screenshots__/worktree-card.spec.tsx"]
    },
    "ct:action-bar": {
      "command": "bun run test:ct -- src/action-bar.spec.tsx",
      "options": { "cwd": "packages/renderer-browser-tests" },
      "cache": true,
      "inputs": ["{projectRoot}/src/action-bar.spec.tsx", "ctShared", "rendererCore"],
      "outputs": ["{projectRoot}/__screenshots__/action-bar.spec.tsx"]
    },
    "ct:diff-popover": {
      "command": "bun run test:ct -- src/diff-popover.spec.tsx",
      "options": { "cwd": "packages/renderer-browser-tests" },
      "cache": true,
      "inputs": ["{projectRoot}/src/diff-popover.spec.tsx", "ctShared", "rendererCore"],
      "outputs": ["{projectRoot}/__screenshots__/diff-popover.spec.tsx"]
    },
    "ct:unified-header": {
      "command": "bun run test:ct -- src/unified-header.spec.tsx",
      "options": { "cwd": "packages/renderer-browser-tests" },
      "cache": true,
      "inputs": ["{projectRoot}/src/unified-header.spec.tsx", "ctShared", "rendererCore"],
      "outputs": ["{projectRoot}/__screenshots__/unified-header.spec.tsx"]
    },
    "test:ct": {
      "dependsOn": [
        "ct:folder-node",
        "ct:file-node",
        "ct:file-list-panel",
        "ct:worktree-card",
        "ct:action-bar",
        "ct:diff-popover",
        "ct:unified-header"
      ],
      "command": "echo 'All component tests completed'",
      "cache": false
    }
  }
}
